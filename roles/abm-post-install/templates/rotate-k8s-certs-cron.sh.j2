{{ node_index % 60 }} {{ cert_rotation_cron_hour }} * {{ cert_rotation_cron_months }} * runuser -l '{{ ansible_user  }}' -c '{{ abm_install_folder }}/scripts/rotate-k8s-certs.sh' >> '{{ abm_install_folder }}/scripts/rotate-certs.log 2>&1'