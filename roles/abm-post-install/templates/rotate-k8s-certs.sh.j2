#!/bin/bash

### Preconditions for script running
# Check if the script is run by root (UID 0)
if [[ "$UID" -eq 0 ]]; then
  >&2 echo "This script should not be run as root."
  exit 1
fi

# Make sure sudo is possible
if ! sudo -v; then
  echo "User running this script cannot sudo. Please check your sudo configuration."
  exit 1
fi

### Variables
TEMPD=$(mktemp -d -t "kube-backup-XXXXXX")
TIMESTAMP=$(date +"%Y%m%d-%H%M%S")
BACKUP_FILE="${TEMPD}/gdc-etc-kube-${TIMESTAMP}.tar.gz"
ADMIN_CONF="/etc/kubernetes/admin.conf"
TARGET_KUBECONFIG="/var/abm-install/kubeconfig/kubeconfig"

# Distributed Lock Variables
LOCK_BUCKET="gs://{{ snapshot_gcs_bucket_base }}"
LOCK_FILE="{{ cluster_name }}-cert-rotation.lock"
LOCK_URI="${LOCK_BUCKET}/${LOCK_FILE}"
TTL_SECONDS=$(( {{ cert_rotation_lock_ttl_hours }} * 3600 ))
NODE_NAME=$(hostname)

### GCS Distributed Lock Logic

acquire_lock() {
    echo "Node ${NODE_NAME} attempting to acquire cluster-wide lock at ${LOCK_URI}..."
    echo "Owner: ${NODE_NAME}, Time: $(date -u)" > /tmp/cert-rotation-lock-info

    # Atomic creation: fails if exists
    if {% if DRY_RUN is defined and DRY_RUN %}echo "[DRY RUN] Would run: "{% endif %}gcloud storage cp /tmp/cert-rotation-lock-info "${LOCK_URI}" --header="x-goog-if-generation-match: 0" &>/dev/null; then
        return 0
    fi
    return 1
}

check_stale_lock() {
    echo "Checking if existing lock is stale..."
    UPDATED_STR=$(gcloud storage objects describe "${LOCK_URI}" --format="value(updated)" 2>/dev/null)
    if [ -z "$UPDATED_STR" ]; then
        # File might have been deleted just now, or there's an error reading it
        return 1
    fi

    UPDATED_EPOCH=$(date -d "$UPDATED_STR" +%s)
    CURRENT_EPOCH=$(date +%s)
    AGE=$((CURRENT_EPOCH - UPDATED_EPOCH))

    if [ $AGE -gt $TTL_SECONDS ]; then
        echo "Stale lock detected (Age: ${AGE}s > TTL: ${TTL_SECONDS}s). Clearing stale lock..."
        {% if DRY_RUN is defined and DRY_RUN %}echo "[DRY RUN] Would run: "{% endif %}gcloud storage rm "${LOCK_URI}"
        return 0 # Lock was stale and cleared
    fi
    return 1 # Lock is still valid
}

### Lock Acquisition Loop
if ! acquire_lock; then
    if check_stale_lock; then
        # Stale lock was cleared, try acquiring again
        if ! acquire_lock; then
            echo "ABORT: Failed to acquire lock after clearing stale lock. Exiting."
            exit 0
        fi
    else
        echo "ABORT: Lock held by another node (or unable to determine lock age). Exiting."
        exit 0
    fi
fi

# Ensure lock is released on exit (whether success or failure)
trap '{% if DRY_RUN is defined and DRY_RUN %}echo "[DRY RUN] Would release lock: "{% endif %}gcloud storage rm "${LOCK_URI}"' EXIT

echo "Lock acquired successfully. Proceeding with certificate rotation..."

### Script Start
# Check to see if certs are out-of-date
CERT_CONDITION=$(grep 'client-certificate-data' /var/abm-install/kubeconfig/kubeconfig | awk '{print $2}' | base64 -d | openssl x509 -text | grep Validity -A2)
if [[ $? > 0 ]]; then
    >&2 echo "Certificates are already out of date and cannot be automated for replacement."
    exit 1
fi

# Exit if the temp directory wasn't created successfully.
if [ ! -e "$TEMPD" ]; then
    >&2 echo "Failed to create temp directory"
    exit 1
fi

### Rollback Function
rollback() {
    echo "CRITICAL: An error occurred. Restoring /etc/kubernetes..."
    if [ -f "$BACKUP_FILE" ]; then
        {% if DRY_RUN is defined and DRY_RUN %}
        echo "[DRY RUN] Would run: sudo rm -rf /etc/kubernetes/*"
        echo "[DRY RUN] Would run: sudo tar -xzf $BACKUP_FILE -C /"
        {% else %}
        sudo rm -rf /etc/kubernetes/*
        sudo tar -xzf "$BACKUP_FILE" -C /
        {% endif %}
        echo "Restore complete."
    else
        echo "Error: Backup file not found!"
    fi
}

### 1. Pre-Check & Backup
echo "Backing up /etc/kubernetes to ${BACKUP_FILE}..."
{% if DRY_RUN is defined and DRY_RUN %}
echo "[DRY RUN] Would run: sudo tar -zcvf $BACKUP_FILE /etc/kubernetes"
{% else %}
sudo tar -zcvf "$BACKUP_FILE" /etc/kubernetes || { echo "Backup failed."; exit 1; }
{% endif %}

### 2. Renew Certificates
echo "Renewing certificates..."
{% if DRY_RUN is defined and DRY_RUN %}
echo "[DRY RUN] Would run: sudo kubeadm certs renew all"
{% else %}
if ! sudo kubeadm certs renew all; then
    rollback
    exit 1
fi
{% endif %}

### 3. Restart Control Plane
echo "Restarting containers..."
{% if DRY_RUN is defined and DRY_RUN %}
echo "[DRY RUN] Would run: sudo crictl ps | grep -E 'kube-scheduler|kube-controller-manager|kube-apiserver' | awk '{print $1}'"
echo "[DRY RUN] Would run: sudo crictl stop \$IDS"
{% else %}
IDS=$(sudo crictl ps | grep -E 'kube-scheduler|kube-controller-manager|kube-apiserver' | awk '{print $1}')
[ -n "$IDS" ] && sudo crictl stop $IDS
{% endif %}

# Brief sleep to let Kubelet start the API server back up
echo "Waiting 10 seconds for API server to stabilize..."
sleep 10

### 4. Validate admin.conf
echo "Testing connectivity with renewed admin.conf..."
{% if DRY_RUN is defined and DRY_RUN %}
echo "[DRY RUN] Would run: sudo kubectl get nodes --kubeconfig $ADMIN_CONF"
echo "Validation Successful! Syncing to $TARGET_KUBECONFIG"
{% else %}
if sudo kubectl get nodes --kubeconfig "$ADMIN_CONF" > /dev/null 2>&1; then
    echo "Validation Successful! Syncing to $TARGET_KUBECONFIG"

    # Copy and set permissions (666)
    sudo cp "$ADMIN_CONF" "$TARGET_KUBECONFIG"
    sudo chmod 666 "$TARGET_KUBECONFIG"

    echo "Permissions set to 666 for $TARGET_KUBECONFIG"
else
    echo "Error: kubectl test failed with the new admin.conf!"
    rollback
    exit 1
fi
{% endif %}

### 5. Final Expiration Check
{% if DRY_RUN is defined and DRY_RUN %}
echo "[DRY RUN] Would run: sudo kubeadm certs check-expiration"
{% else %}
sudo kubeadm certs check-expiration
{% endif %}
echo "Process complete!"

# Prevent subsequent staggered cron jobs from picking up a prematurely released lock
echo "Rotation complete. Sleeping 5 minutes to bridge the stagger window before releasing lock..."
sleep 300
